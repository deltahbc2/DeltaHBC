<section id="contact" class="py-24 px-6">
    <div class="max-w-300 mx-auto px-2 md:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 space-y-8">
            <div class="flex flex-col justify-center">
                <h2 class="font-semibold text-3xl mb-4">¿Tienes algun proyecto en mente?</h2>
                <p class="text-lg md:text-xl text-gray-400 mb-6">
                    Si tienes alguna pregunta, inquietud o simplemente quieres conectarte con nosotros, no dudes en contactarnos. Estamos aquí para ayudarte y colaborar en proyectos que generen un impacto positivo.
                </p>

                <div class="space-y-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-neutral-800 flex items-center justify-center text-[#bec6e0]">
                            <i class="fa-regular fa-envelope text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-gray-400 font-mono">Correo Electrónico</p>
                            <a href="mailto:contacto@deltahbc.com" target="_blank" class="font-semibold text-md">contacto@deltahbc.com</a>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-neutral-800 flex items-center justify-center text-[#bec6e0]">
                            <i class="fa-brands fa-whatsapp text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-gray-400 font-mono">Whatsapp</p>
                            <a href="https://wa.me/528147990195" target="_blank" class="font-semibold text-md">+52 81 4799 0195</a>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-lg bg-neutral-800 flex items-center justify-center text-[#bec6e0]">
                            <i class="fa-solid fa-map-pin text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-gray-400 font-mono">Ubicación</p>
                            <p class="font-semibold text-md">Monterrey, Nuevo León</p>
                        </div>
                    </div>
                </div>
            </div>

            <form action="https://formsubmit.co/af7539e27312c97ac9f6df1531825877" method="POST" class="space-y-6 p-8 md:p-12 bg-neutral-900 border border-blue-800/20 rounded-2xl">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label for="name" class="block text-lg text-gray-400 font-mono mb-1">Nombre</label>
                        <input id="name" name="Nombre" aria-label="Nombre" class="w-full bg-neutral-800 border border-blue-800/20 rounded-lg focus:outline-none p-2" type="text" required autocomplete="name"/>
                    </div>
                    <div>
                        <label for="email" class="block text-lg text-gray-400 font-mono mb-1">Correo Electrónico</label>
                        <input id="email" name="Email" aria-label="Email" class="w-full bg-neutral-800 border border-blue-800/20 rounded-lg focus:outline-none p-2" type="email" required autocomplete="email"/>
                    </div>
                </div>

                <div>
                    <label for="subject" class="block text-lg text-gray-400 font-mono mb-1">Asunto</label>
                    <input id="subject" name="Asunto" aria-label="Asunto" class="w-full bg-neutral-800 border border-blue-800/20 rounded-lg focus:outline-none p-2" type="text" required />
                </div>

                <div>
                    <label for="message" class="block text-lg text-gray-400 font-mono mb-1">Mensaje</label>
                    <textarea id="message" name="Mensaje" aria-label="Mensaje" class="w-full bg-neutral-800 border border-blue-800/20 rounded-lg focus:outline-none p-2 min-h-12 max-h-48" rows="4"></textarea>
                </div>

                <button class="w-full py-2 bg-[#bec6e0] text-lg text-black font-bold rounded-lg hover:brightness-110 active:scale-[0.98] transition-all" type="submit">Enviar</button>
            </form>
        </div>
