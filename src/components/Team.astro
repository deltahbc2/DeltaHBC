---

const teamMembers = [
    {
        name: 'César Oliva',
        role: 'Frontend Developer',
        image: 'Images/CesarOliva.webp',
        enlaces: {
            linkedin: 'https://www.linkedin.com/in/olivavc/',
            portafolio: 'https://bycesaroliva.com'
        }
    },
    {
        name: 'André Anzures',
        role: 'Backend Developer',
        image: 'Images/AndreAnzures.webp',
    },
    {
        name: 'Oscar Santiago',
        role: 'AI Specialist',
        image: 'Images/OscarSantiago.webp',
    }
];

---

<section id="team" class="py-24 px-6">
    <div class="max-w-300 mx-auto px-2 md:px-12">
        <h2 class="text-[#bec6e0] text-4xl font-bold md:text-start text-center mb-4">Equipo</h2>
        <p class="text-gray-400 text-lg md:text-start text-center mb-12">
            Conoce al equipo detras de DeltaHBC. Un equipo de desarrolladores apasionados por la tecnología y el impacto social.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {teamMembers.map((member) => (
                <div class="group">
                    <div class="aspect-4/5 rounded-2xl overflow-hidden mb-4 relative">
                        <img src={member.image} alt={member.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">

                        <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            {member.enlaces?.linkedin && (
                                <a href={member.enlaces.linkedin} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-white hover:bg-brand-purple">
                                    <i class="text-sm fab fa-linkedin-in"></i>
                                </a>
                            )}
    
                            {member.enlaces?.portafolio && (
                                <a href={member.enlaces.portafolio} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-white hover:bg-brand-purple">
                                    <i class="text-sm fas fa-globe"></i>
                                </a>
                            )}
                        </div>
                    </div>
                    
                    <h4 class="text-2xl font-bold text-white">{member.name}</h4>
                    <p class="text-blue-400/80 text-md font-medium">{member.role}</p>
                </div>
            ))}
        </div>
    </div>
</section>