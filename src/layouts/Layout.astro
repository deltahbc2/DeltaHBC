---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  locale?: 'es-MX' | 'en-US';
  robots?: string;
  canonical?: string;
  siteName?: string;
  ogImage?: string;
  ogImageAlt?: string;
  author?: string;
}

const {
  title = 'DeltaHBC',
  description = 'DeltaHBC desarrolla soluciones tecnológicas con enfoque en impacto social, accesibilidad e innovación.',
  keywords = 'startup tecnológica, impacto social, desarrollo web, innovación, accesibilidad, DeltaHBC',
  locale = 'es-MX',
  robots = 'index, follow',
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  siteName = 'DeltaHBC',
  ogImage = 'https://deltahbc.com/Images/Hero.webp',
  ogImageAlt = 'DeltaHBC | Soluciones Tecnológicas de Impacto Social',
  author = 'DeltaHBC',
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const currentUrl = Astro.url.toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  description,
  url: 'https://deltahbc.com',
  logo: {
    '@type': 'ImageObject',
    url: ogImage,
    width: 1200,
    height: 630,
  },
  sameAs: [
    // 'https://www.linkedin.com/company/deltahbc',
    // 'https://twitter.com/deltahbc',
    'https://github.com/deltahbc2',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'Customer Support',
    availableLanguage: ['es', 'en'],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  description,
  url: 'https://deltahbc.com',
  inLanguage: locale,
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://deltahbc.com?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang={locale}>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
	<meta name="generator" content={Astro.generator} />
	
	<!-- Primary Meta Tags -->
	<meta name="title" content={title} />
	<meta name="description" content={description} />
	<meta name="keywords" content={keywords} />
	<meta name="author" content={author} />
	<meta name="robots" content={robots} />
	<meta name="revisit-after" content="7 days" />
	
	<!-- Theme & Color Scheme -->
	<meta name="theme-color" content="#03060A" />
	<meta name="color-scheme" content="dark light" />
	
	<!-- Canonical URL -->
	<link rel="canonical" href={canonicalUrl} />
	
	<!-- Open Graph / Facebook -->
	<meta property="og:type" content="website" />
	<meta property="og:url" content={currentUrl} />
	<meta property="og:site_name" content={siteName} />
	<meta property="og:locale" content={locale === 'es-MX' ? 'es_MX' : 'en_US'} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={ogImage} />
	<meta property="og:image:alt" content={ogImageAlt} />
	<meta property="og:image:width" content="1200" />
	<meta property="og:image:height" content="630" />
	<meta property="og:image:type" content="image/webp" />
	
	<!-- Twitter -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:url" content={currentUrl} />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={ogImage} />
	<meta name="twitter:image:alt" content={ogImageAlt} />
	<meta name="twitter:creator" content="@deltahbc" />
	
	<!-- Favicons -->
	<link rel="icon" href="/Images/Hero.webp" type="image/webp" />
	<link rel="shortcut icon" href="/Images/Hero.webp" />
	<link rel="apple-touch-icon" href="/Images/Hero.webp" />
	
	<!-- Manifest for PWA -->
	<link rel="manifest" href="/manifest.json" />
	
	<!-- Title -->
	<title>{title}</title>
	
	<!-- Preconnect to external domains for performance -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link rel="dns-prefetch" href="https://kit.fontawesome.com" />
	
	<!-- Structured Data (JSON-LD) -->
	<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
	
	<!-- Font Awesome -->
	<script src="https://kit.fontawesome.com/17383348a8.js" crossorigin="anonymous" defer></script>
</head>
<body class="antialiased" role="application" aria-label={title}>
	<a href="#content" class="sr-only">Saltar al contenido principal</a>
	<main id="content" role="main" tabindex="-1">
		<slot />
	</main>
</body>
</html>