---

import '../styles/global.css';

const {
	title = 'DeltaHBC',
	description = 'Startup tecnológica enfocada en resolver problemas de alto impacto social con soluciones innovadoras y centradas en las personas.',
} = Astro.props;

---

<!doctype html>
<html lang="es-MX">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow" />
	<meta name="theme-color" content="#03060A" />
	<meta name="color-scheme" content="dark" />
	<meta property="og:site_name" content="DeltaHBC" />
	<meta property="og:locale" content="es_MX" />
	<meta property="og:type" content="website" />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<title>{title}</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<script src="https://kit.fontawesome.com/17383348a8.js" crossorigin="anonymous"></script>
</head>
<body>
	<main id="content" tabindex="-1">
		<slot />
	</main>
</body>
</html>